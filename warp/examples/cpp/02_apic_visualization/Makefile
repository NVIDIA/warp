# Makefile for APIC Wave Visualization Example
#
# This builds a C++ program that loads a pre-captured CUDA graph
# and visualizes it using GLFW/OpenGL.

# Compiler
NVCC := nvcc

# Target executable (named after example directory)
TARGET := 02_apic_visualization

# Source files
SOURCES := main.cu

# Graph file (generated by Python capture script)
GRAPH_FILE := generated/wave_sim.wrp

# Warp native directory (relative path from example to repo root)
# Override by setting WARP_NATIVE_DIR environment variable
WARP_NATIVE_DIR ?= ../../../native
WARP_INCLUDE := $(WARP_NATIVE_DIR)

# Warp bin directory (for libwarp.so)
WARP_BIN_DIR ?= ../../../bin
WARP_LIB := $(WARP_BIN_DIR)

# Detect OS for platform-specific flags
UNAME_S := $(shell uname -s)

# CUDA architecture for the device-side update_vertices kernel.
# Override with: make CUDA_ARCH=sm_90 (or any supported gencode target).
CUDA_ARCH ?= sm_80

# Compiler flags
NVCC_FLAGS := -std=c++17 \
              -O3 \
              -arch=$(CUDA_ARCH) \
              -isystem $(WARP_INCLUDE) \
              -Xcompiler -Wall

# Platform-specific linker flags
ifeq ($(UNAME_S),Linux)
    LDFLAGS := -lcuda -lcudart -lGL -lglfw -L$(WARP_LIB) -l:warp.so -Wl,-rpath,$(WARP_LIB)
else ifeq ($(UNAME_S),Darwin)
    $(error macOS is not supported - CUDA not available on macOS)
else
    # Windows (MinGW/Cygwin)
    LDFLAGS := -lcuda -lcudart -lopengl32 -lglfw3 -L$(WARP_LIB) -lwarp
endif

# Sentinel file to track graph generation
GRAPH_SENTINEL := generated/.graph_captured

# Default target - build everything
.PHONY: all
all: $(TARGET)

# Generate APIC graph (dependency for target)
$(GRAPH_SENTINEL): capture_wave.py
	@echo "Capturing wave simulation graph..."
	@if command -v uv >/dev/null 2>&1; then \
		uv run capture_wave.py; \
	else \
		python3 capture_wave.py; \
	fi
	@touch $(GRAPH_SENTINEL)
	@echo ""

# Build the executable (depends on graph being generated)
$(TARGET): $(GRAPH_SENTINEL) $(SOURCES)
	@if [ ! -d "$(WARP_INCLUDE)" ]; then \
		echo "Error: Warp native directory not found at: $(WARP_INCLUDE)"; \
		echo "Make sure you're running from warp/examples/cpp/02_apic_visualization/"; \
		echo "Or set WARP_NATIVE_DIR to point to warp/native/"; \
		exit 1; \
	fi
	@if [ ! -f "$(GRAPH_FILE)" ]; then \
		echo "Error: APIC graph not found at: $(GRAPH_FILE)"; \
		echo "Run 'python capture_wave.py' first."; \
		exit 1; \
	fi
	@echo "Building APIC visualization..."
	$(NVCC) $(NVCC_FLAGS) $(SOURCES) -o $(TARGET) $(LDFLAGS)
	@echo ""
	@echo "Build successful! Run with: ./02_apic_visualization"

# Build only the C++ program (assumes graph already exists)
.PHONY: cpp
cpp: $(SOURCES)
	@if [ ! -d "$(WARP_INCLUDE)" ]; then \
		echo "Error: Warp native directory not found at: $(WARP_INCLUDE)"; \
		exit 1; \
	fi
	@if [ ! -f "$(GRAPH_FILE)" ]; then \
		echo "Error: APIC graph not found. Run 'python capture_wave.py' first."; \
		exit 1; \
	fi
	@echo "Building APIC visualization (skipping graph capture)..."
	$(NVCC) $(NVCC_FLAGS) $(SOURCES) -o $(TARGET) $(LDFLAGS)
	@echo ""
	@echo "Build successful! Run with: ./02_apic_visualization"

# Capture graph only
.PHONY: capture
capture:
	@echo "Capturing wave simulation graph..."
	@if command -v uv >/dev/null 2>&1; then \
		uv run capture_wave.py; \
	else \
		python3 capture_wave.py; \
	fi

# Clean build artifacts
.PHONY: clean
clean:
	rm -f $(TARGET)
	@echo "Cleaned build artifacts"

# Clean everything including generated files
.PHONY: distclean
distclean: clean
	rm -rf generated/
	@echo "Cleaned all generated files"

# Help target
.PHONY: help
help:
	@echo "APIC Wave Visualization Example - Makefile"
	@echo ""
	@echo "Targets:"
	@echo "  all (default)   - Build everything (auto-captures graph if needed)"
	@echo "  cpp             - Build only C++ program (for iterating on C++ code)"
	@echo "  capture         - Capture the APIC graph only (no C++ build)"
	@echo "  clean           - Remove build artifacts"
	@echo "  distclean       - Remove build artifacts and generated/ directory"
	@echo "  help            - Show this help message"
	@echo ""
	@echo "Environment variables:"
	@echo "  WARP_NATIVE_DIR - Path to warp/native/ directory"
	@echo "  WARP_BIN_DIR    - Path to warp/bin/ directory (for libwarp.so)"
	@echo ""
	@echo "Usage:"
	@echo "  1. Run: make"
	@echo "  2. Run: ./02_apic_visualization"
	@echo "  3. Left-click to create waves, right-drag to rotate, scroll to zoom"
