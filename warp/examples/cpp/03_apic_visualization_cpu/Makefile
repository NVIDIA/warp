# Makefile for APIC Wave Visualization Example (CPU)
#
# This builds a C++ program that loads a pre-captured APIC graph
# and replays it on the CPU using GLFW/OpenGL for visualization.
# No CUDA toolchain is required to build or run the example itself.

# Compiler
CXX ?= g++

# Target executable (named after example directory)
TARGET := 03_apic_visualization_cpu

# Source files
SOURCES := main.cpp

# Graph file (generated by Python capture script)
GRAPH_FILE := generated/wave_sim.wrp

# glad OpenGL loader (generated by glad2 PyPI package; mirrors what CMake's
# FetchContent + glad_add_library does in the CMake build)
GLAD_DIR := generated/glad
GLAD_HEADER := $(GLAD_DIR)/include/glad/gl.h
GLAD_SOURCE := $(GLAD_DIR)/src/gl.c

# Warp native directory (relative path from example to repo root)
# Override by setting WARP_NATIVE_DIR environment variable
WARP_NATIVE_DIR ?= ../../../native
WARP_INCLUDE := $(WARP_NATIVE_DIR)

# Warp bin directory (for libwarp.so / warp.dll)
WARP_BIN_DIR ?= ../../../bin
WARP_LIB := $(WARP_BIN_DIR)

# Detect OS for platform-specific flags
UNAME_S := $(shell uname -s)

# Compiler flags
CXX_FLAGS := -std=c++17 \
             -O3 \
             -isystem $(WARP_INCLUDE) \
             -isystem $(GLAD_DIR)/include \
             -Wall

# Platform-specific linker flags
# The trailing --unresolved-symbols flag tolerates Py* references in
# warp.so; see CMakeLists.txt for full rationale.
ifeq ($(UNAME_S),Linux)
    LDFLAGS := -ldl -lGL -lglfw -L$(WARP_LIB) -l:warp.so -Wl,-rpath,$(WARP_LIB) -Wl,--unresolved-symbols=ignore-in-shared-libs
else ifeq ($(UNAME_S),Darwin)
    LDFLAGS := -ldl -framework OpenGL -lglfw -L$(WARP_LIB) -lwarp -Wl,-rpath,$(WARP_LIB)
else
    # Windows (MinGW/Cygwin)
    LDFLAGS := -lopengl32 -lglfw3 -L$(WARP_LIB) -lwarp
endif

# Sentinel file to track graph generation
GRAPH_SENTINEL := generated/.graph_captured

# Default target - build everything
.PHONY: all
all: $(TARGET)

# Generate APIC graph (dependency for target)
$(GRAPH_SENTINEL): capture_wave.py
	@echo "Capturing wave simulation graph (CPU)..."
	@if command -v uv >/dev/null 2>&1; then \
		uv run capture_wave.py; \
	else \
		python3 capture_wave.py; \
	fi
	@touch $(GRAPH_SENTINEL)
	@echo ""

# Generate the glad OpenGL loader. --reproducible uses the GL spec bundled
# with glad2 instead of fetching it from Khronos at build time, matching
# the REPRODUCIBLE flag passed to glad_add_library() in the CMake build.
$(GLAD_HEADER) $(GLAD_SOURCE) &:
	@echo "Generating glad OpenGL loader (gl:core=3.3)..."
	@if command -v uv >/dev/null 2>&1; then \
		uv run --with glad2 python -m glad --api gl:core=3.3 --reproducible --quiet --out-path $(GLAD_DIR) c; \
	else \
		python3 -m glad --api gl:core=3.3 --reproducible --quiet --out-path $(GLAD_DIR) c; \
	fi
	@echo ""

# Build the executable (depends on graph and glad being generated)
$(TARGET): $(GRAPH_SENTINEL) $(GLAD_HEADER) $(GLAD_SOURCE) $(SOURCES)
	@if [ ! -d "$(WARP_INCLUDE)" ]; then \
		echo "Error: Warp native directory not found at: $(WARP_INCLUDE)"; \
		echo "Make sure you're running from warp/examples/cpp/03_apic_visualization_cpu/"; \
		echo "Or set WARP_NATIVE_DIR to point to warp/native/"; \
		exit 1; \
	fi
	@if [ ! -f "$(GRAPH_FILE)" ]; then \
		echo "Error: APIC graph not found at: $(GRAPH_FILE)"; \
		echo "Run 'python capture_wave.py' first."; \
		exit 1; \
	fi
	@$(MAKE) --no-print-directory check-glfw
	@echo "Building APIC visualization (CPU)..."
	$(CXX) $(CXX_FLAGS) $(SOURCES) $(GLAD_SOURCE) -o $(TARGET) $(LDFLAGS)
	@echo ""
	@echo "Build successful! Run with: ./03_apic_visualization_cpu"

# GLFW headers are an unbundled system dependency for the Make build path
# (the CMake build fetches GLFW via FetchContent instead). Probe with the
# host compiler so we can print actionable install hints before the build
# fails with a generic "GLFW/glfw3.h: No such file or directory" message.
.PHONY: check-glfw
check-glfw:
	@if ! { echo '#include <GLFW/glfw3.h>' | $(CXX) -E -x c++ - >/dev/null 2>&1; }; then \
		echo "Error: GLFW development headers not found."; \
		echo "The Makefile build path expects a system install of GLFW. Install with:"; \
		echo "  Debian/Ubuntu: sudo apt install libglfw3-dev"; \
		echo "  Fedora/RHEL:   sudo dnf install glfw-devel"; \
		echo "  Arch:          sudo pacman -S glfw"; \
		echo "  macOS:         brew install glfw"; \
		echo "Alternatively, use the CMake build, which fetches GLFW automatically."; \
		exit 1; \
	fi

# Build only the C++ program (assumes graph and glad already exist)
.PHONY: cpp
cpp: $(SOURCES)
	@if [ ! -d "$(WARP_INCLUDE)" ]; then \
		echo "Error: Warp native directory not found at: $(WARP_INCLUDE)"; \
		exit 1; \
	fi
	@if [ ! -f "$(GRAPH_FILE)" ]; then \
		echo "Error: APIC graph not found. Run 'python capture_wave.py' first."; \
		exit 1; \
	fi
	@if [ ! -f "$(GLAD_SOURCE)" ]; then \
		echo "Error: glad loader not generated. Run 'make' (without 'cpp') first."; \
		exit 1; \
	fi
	@$(MAKE) --no-print-directory check-glfw
	@echo "Building APIC visualization (CPU, skipping graph capture)..."
	$(CXX) $(CXX_FLAGS) $(SOURCES) $(GLAD_SOURCE) -o $(TARGET) $(LDFLAGS)
	@echo ""
	@echo "Build successful! Run with: ./03_apic_visualization_cpu"

# Capture graph only
.PHONY: capture
capture:
	@echo "Capturing wave simulation graph (CPU)..."
	@if command -v uv >/dev/null 2>&1; then \
		uv run capture_wave.py; \
	else \
		python3 capture_wave.py; \
	fi

# Clean build artifacts
.PHONY: clean
clean:
	rm -f $(TARGET)
	@echo "Cleaned build artifacts"

# Clean everything including generated files
.PHONY: distclean
distclean: clean
	rm -rf generated/
	@echo "Cleaned all generated files"

# Help target
.PHONY: help
help:
	@echo "APIC Wave Visualization Example (CPU) - Makefile"
	@echo ""
	@echo "Targets:"
	@echo "  all (default)   - Build everything (auto-captures graph if needed)"
	@echo "  cpp             - Build only C++ program (for iterating on C++ code)"
	@echo "  capture         - Capture the APIC graph only (no C++ build)"
	@echo "  clean           - Remove build artifacts"
	@echo "  distclean       - Remove build artifacts and generated/ directory"
	@echo "  help            - Show this help message"
	@echo ""
	@echo "Environment variables:"
	@echo "  WARP_NATIVE_DIR - Path to warp/native/ directory"
	@echo "  WARP_BIN_DIR    - Path to warp/bin/ directory (for libwarp)"
	@echo "  CXX             - C++ compiler (default: g++)"
	@echo ""
	@echo "Notes:"
	@echo "  - Loading .wrp files currently requires a CUDA-enabled Warp library."
	@echo "  - Graph replay itself is CPU-only with no GPU/CUDA runtime dependency."
	@echo ""
	@echo "Usage:"
	@echo "  1. Run: make"
	@echo "  2. Run: ./03_apic_visualization_cpu"
	@echo "  3. Left-click to create waves, right-drag to rotate, scroll to zoom"
